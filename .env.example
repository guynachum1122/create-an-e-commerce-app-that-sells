# Harvest Basket — Environment Variables
# Copy to .env and fill in values

# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/harvest_basket?schema=public"

# ─── Auth (NextAuth v5) ───────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-in-production"
AUTH_URL="http://localhost:3000"
# Aliases (NextAuth v4 naming — AUTH_* above is preferred for Auth.js v5)
NEXTAUTH_SECRET="change-me-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (optional — leave blank to disable)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Site / SEO ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
SITE_NAME="Harvest Basket"
OG_DEFAULT_IMAGE_URL=""
TWITTER_HANDLE=""
ALLOW_AI_CRAWLERS="false"

# ─── Email (Resend) ───────────────────────────────────────────────────────
# Get key at https://resend.com — blank = emails logged as SKIPPED in dev
RESEND_API_KEY=""
EMAIL_FROM="orders@harvestbasket.com"

# ─── Payments ───────────────────────────────────────────────────────────────
# MOCK (default) — swap to STRIPE later without changing checkout flow
PAYMENT_PROVIDER="MOCK"

# ─── Observability ─────────────────────────────────────────────────────────
# Tier 1 — Sentry (error tracking + performance)
# Get DSN at https://sentry.io — blank = Sentry silently disabled
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# Tier 1 — PostHog (product analytics + funnels)
# Get key at https://posthog.com — blank = disabled
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# Tier 2 — Mixpanel (advanced product analytics)
# Get token at https://mixpanel.com — blank = all calls are no-ops
NEXT_PUBLIC_MIXPANEL_TOKEN=""

# Tier 2 — Datadog (APM + infrastructure)
# Get keys at https://datadoghq.com — blank DD_API_KEY = tracer init skipped
DD_API_KEY=""
DD_APP_KEY=""
DD_SERVICE="harvest-basket"
DD_ENV="development"

# Tier 1 — Vercel Analytics + Speed Insights
# Zero config on Vercel deploy; no-op locally (packages included in app)

# ─── Rate limiting (optional, production) ─────────────────────────────────
# Upstash Redis REST — required on Vercel production; blank = in-memory fallback (dev only)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── Seed (development only) ────────────────────────────────────────────────
SEED_ADMIN_PASSWORD=""
SEED_CUSTOMER_PASSWORD=""
